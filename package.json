{
  "name": "kiro-cli-review-action",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GitHub Action for automated PR code review using kiro-cli",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --outfile=dist/main/index.cjs && esbuild src/post.ts --bundle --platform=node --target=node24 --outfile=dist/post/index.cjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check . && pnpm run typecheck && pnpm run test"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/github": "9.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.5",
    "esbuild": "0.28.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
